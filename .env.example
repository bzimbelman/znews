# Local development environment variables
# Copy this file to .env.local and update with your local configuration

# Database URLs
TEST_DATABASE_URL=postgresql://znews:znews_password@localhost:5432/znews_test
REDIS_URL=redis://localhost:6380
RABBITMQ_URL=amqp://znews:znews_password@localhost:5673/znews

# Service ports (optional - can be set in docker-compose.override.yml)
FEED_SERVICE_PORT=3000
DISCOVERY_SERVICE_PORT=8000
CRAWLER_SERVICE_PORT=8080

# Default values for services
NODE_ENV=development
PYTHON_ENV=development
GO_ENV=development

# Logging
LOG_LEVEL=info

# Test configuration
JEST_JUNIT_REPORT_DIR=test-reports
PYTEST_COVERAGE_XML=coverage.xml