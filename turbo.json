{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"],
      "passThroughEnv": [
        "NODE_ENV",
        "CI",
        "TEST_DATABASE_URL",
        "REDIS_URL",
        "RABBITMQ_URL"
      ]
    },
    "clean": {
      "cache": false
    },
    "type-check": {
      "dependsOn": ["build"],
      "outputs": []
    }
  }
}
